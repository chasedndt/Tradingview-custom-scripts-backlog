showFlipLabels = input.bool(true, "Show Bias Flip Labels",
     tooltip = "Display 'BIAS FLIP ↑' / 'BIAS FLIP ↓' labels on chart.",
     group = grpDisplay)

showEMAs = input.bool(true, "Plot EMA Lines", group = grpDisplay)

showSwingLevels = input.bool(true, "Show Swing Level Lines", group = grpDisplay)

showInfoPanel = input.bool(true, "Show Status Panel",
     tooltip = "Small table showing current biasState, emaTrend, trendState, and last swing levels.",
     group = grpDisplay)

labelSize = input.string("small", "Label Size",
     options = ["tiny", "small", "normal"],
