swingLen = input.int(12, "Swing Length",
     minval = 1, maxval = 50,
     tooltip = "Bars to left AND right to confirm a swing pivot.\n" +
               "Higher = fewer but more significant swings.\n" +
               "Lower = more swings, more signals, more noise.\n" +
               "Recommended: 8-15 for intraday, 12-20 for daily+.",
     group = grpStructure)

breakMode = input.string("Close", "Break Confirmation Mode",
     options = ["Close", "Wick"],
     tooltip = "How we confirm a structure break:\n" +
               "Close: Candle must CLOSE beyond the level (safer, fewer false breaks)\n" +
               "Wick: High/Low touching beyond level counts (faster, more signals)",
     group = grpStructure)

atrBufferEnabled = input.bool(false, "Enable ATR Buffer",
     tooltip = "Adds a buffer zone around swing levels.\n" +
               "Price must break level + buffer to trigger.\n" +
               "Helps reduce false breaks in choppy/ranging markets.",
     group = grpStructure)

atrLen = input.int(14, "ATR Length",
     minval = 1, maxval = 100,
     group = grpStructure)

atrBufferMult = input.float(0.0, "ATR Buffer Multiplier",
