// ============================================================================
// SECTION 2: COLOR DEFINITIONS
// ============================================================================
// Centralizing colors as constants makes the code WAY easier to maintain.
// Want to change the bullish flip color? Change it in ONE place, not twenty.
//
// DESIGN PRINCIPLE: Bias Flip colors should be DISTINCT from BOS/CHoCH colors
// so the user can instantly tell "this is a BIAS event, not just a structure event."
// We use blue/magenta for bias flips vs green/red/teal/orange for structure.
// ============================================================================

// --- Bias Flip Colors (the main event) ---
color COLOR_FLIP_BULL   = color.new(#00BFFF, 0)   // Deep sky blue — bullish flip
color COLOR_FLIP_BEAR   = color.new(#FF1493, 0)   // Deep pink — bearish flip

// --- Structure Event Colors (MSA inherited) ---
color COLOR_BOS_BULL    = color.new(color.green,  0)
color COLOR_BOS_BEAR    = color.new(color.red,    0)
color COLOR_CHOCH_BULL  = color.new(color.teal,   0)
color COLOR_CHOCH_BEAR  = color.new(color.orange,  0)

// --- Swing Level Line Colors ---
color COLOR_SWING_HIGH  = color.new(color.red,   50)
color COLOR_SWING_LOW   = color.new(color.green, 50)

// --- Background Colors (very faint so they don't obscure candles) ---
color COLOR_BG_BULL     = color.new(color.green, 92)
color COLOR_BG_BEAR     = color.new(color.red,   92)


// ============================================================================
// SECTION 3: GLOBAL-SCOPE STATEFUL CALCULATIONS
// ============================================================================
// THIS IS CRITICAL IN PINE SCRIPT v6.
//
// Pine v6 introduced "lazy boolean evaluation" (short-circuit logic):
//   - `condition1 and condition2` — if condition1 is false, condition2 is SKIPPED
//   - This is great for performance but DEADLY for stateful functions
//
// Why? Functions like ta.ema(), ta.atr(), ta.pivothigh() maintain internal
// history. If they get "skipped" on some bars due to lazy eval, their history
// becomes corrupted and values go haywire.
//
// THE FIX: Calculate ALL stateful series at GLOBAL scope (top level), BEFORE
// using them in any `if` block or `and`/`or` expression.
//
// This is like prepping all your ingredients before you start cooking.
// You don't want to be chopping onions mid-stir-fry.
// ============================================================================

// --- EMA Calculations (global scope — NEVER put these inside an if block) ---
emaFast = ta.ema(close, fastEmaLen)
emaSlow = ta.ema(close, slowEmaLen)

// --- ATR Calculation (global scope) ---
// Even if ATR buffer is disabled, we calculate it every bar to keep history clean.
// The cost is negligible and prevents lazy-eval corruption.
atrValue = ta.atr(atrLen)

// --- Pivot Detection (global scope) ---
// ta.pivothigh/low return the HIGH/LOW value if a pivot was confirmed, else na.
// Pivots confirm swingLen bars AFTER they actually occurred (built-in lag).
// This lag is a FEATURE, not a bug — it ensures pivots are confirmed and stable.
pivotHigh = ta.pivothigh(high, swingLen, swingLen)
pivotLow  = ta.pivotlow(low,  swingLen, swingLen)

// --- EMA Trend Direction ---
// Simple comparison: which EMA is on top?
// +1 = fast above slow (bullish trend)
// -1 = fast below slow (bearish trend)
int emaTrend = emaFast > emaSlow ? 1 : -1


// ============================================================================
// SECTION 4: STATE VARIABLES (Persisted Across Bars)
// ============================================================================
// The `var` keyword is one of Pine Script's most important features.
//
// WITHOUT var: variable resets to its initial value on EVERY bar.
// WITH    var: variable initializes ONCE and keeps its value across all bars.
//
// Think of `var` like saving your game progress. Without it, you'd restart
// from level 1 every single bar. With it, you pick up where you left off.
//
// We need persistence for:
//   - Swing levels (track the last confirmed highs/lows)
//   - Trend state (remember if we're bullish or bearish)
//   - Bias state (the final output)
//   - Cooldown tracking (when was the last flip?)
//   - Pending flip state (for CHoCHThenBOS modes)
// ============================================================================

// --- Swing Level Tracking ---
var float lastSwingHighLevel = na    // Price of last confirmed swing high
var int   lastSwingHighBar   = na    // Bar index where it occurred
var float lastSwingLowLevel  = na    // Price of last confirmed swing low
var int   lastSwingLowBar    = na    // Bar index where it occurred

// --- MSA Trend State Machine ---
// This tracks the RAW structure direction based on BOS/CHoCH events.
// +1 = bullish structure, -1 = bearish structure, 0 = unknown/init
var int trendState = 0

// --- Bias State (THE MAIN OUTPUT) ---
// This is what the user trades. It only changes on confirmed bias flips.
// +1 = bullish bias, -1 = bearish bias, 0 = unknown
var int biasState = 0

// --- Cooldown Tracking ---
// Stores the bar_index of the last bias flip so we can enforce minimum spacing
var int lastFlipBar = -999999

// --- Pending Flip State (for CHoCHThenBOS modes) ---
// When a CHoCH occurs but we need a follow-up BOS to confirm,
// we store the "pending" direction here.
// 0 = no pending flip, +1 = pending bullish, -1 = pending bearish
var int pendingFlipDir = 0

// --- Drawing Object Arrays ---
// We store references to labels so we can clean up old ones
var array<label> flipLabels = array.new_label()

// --- Active Swing Level Lines ---
var line activeHighLine = na
var line activeLowLine  = na


// ============================================================================
// SECTION 5: HELPER FUNCTIONS
// ============================================================================
// Functions are your best friend in Pine Script. They:
//   1) Make code readable (a name is worth a thousand comments)
//   2) Reduce duplication (DRY — Don't Repeat Yourself)
//   3) Make testing easier (isolate logic into small pieces)
//
// In Pine v6, functions must be DECLARED before they're CALLED.
// Order matters! If function B calls function A, declare A first.
// ============================================================================

// --- Label Size Mapper ---
// Maps our string input to Pine's built-in size constants.
// Pine doesn't let you use strings directly for sizes, so we need this bridge.
getLabelSize() =>
    switch labelSize
        "tiny"   => size.tiny
        "small"  => size.small
        "normal" => size.normal
        => size.small

// --- ATR Buffer Calculator ---
// Returns how much "extra" price movement is needed beyond a swing level
// for the break to count. Returns 0.0 if ATR buffer is disabled.
getAtrBuffer() =>
    atrBufferEnabled ? atrValue * atrBufferMult : 0.0

// --- Break Detection: Has Price Broken ABOVE a Level? ---
// Respects the breakMode setting (Close vs Wick).
// Close mode: the candle body must close above the level.
// Wick mode: the candle high touching above the level counts.
hasBrokenAbove(float level, float buffer) =>
    if na(level)
        false
    else
        float breakPrice = breakMode == "Close" ? close : high
        breakPrice > level + buffer

// --- Break Detection: Has Price Broken BELOW a Level? ---
hasBrokenBelow(float level, float buffer) =>
    if na(level)
        false
    else
        float breakPrice = breakMode == "Close" ? close : low
        breakPrice < level - buffer

// --- Drawing Cleanup ---
// Prevents chart clutter by removing the oldest labels when we exceed our limit.
// Without this, after hundreds of bars you'd have a mess of overlapping labels.
cleanupOldLabels(array<label> labels, int maxItems) =>
    while array.size(labels) > maxItems
        label oldLabel = array.shift(labels)   // Remove from front (oldest)
        label.delete(oldLabel)                 // Delete from chart

// --- JSON String Escaper ---
// THIS IS CRITICAL FOR WEBHOOK SAFETY.
//
// Why do we need this? Because our alert message gets embedded inside a JSON
// string (between double quotes). If any of our dynamic content contains
// characters that are special in JSON (like " or \ or newlines), the JSON
// breaks and Discord rejects the webhook.
//
// Example without escaping:
//   Symbol: NYSE:BRK"A  →  {"content":"...BRK"A..."}  →  BROKEN JSON!
//
// Example with escaping:
//   Symbol: NYSE:BRK"A  →  {"content":"...BRK\"A..."}  →  Valid JSON ✓
//
// ORDER MATTERS: We escape backslashes FIRST, then quotes, then newlines.
// If we escaped quotes first, we'd double-escape the backslashes we just added.
jsonEscape(string s) =>
    string result = str.replace_all(s,  "\\", "\\\\")   // Step 1: \ → \\
    result := str.replace_all(result,   "\"", "\\\"")    // Step 2: " → \"
    result := str.replace_all(result,   "\n", "\\n")     // Step 3: newline → \n
    result

// --- Timestamp Formatter ---
// Creates a human-readable UTC/GMT timestamp for alert messages.
formatTimestamp() =>
    str.format_time(time, "yyyy-MM-dd HH:mm:ss", "GMT")

// --- Bias State to Human-Readable String ---
biasToString(int bias) =>
    switch bias
        1  => "BULLISH"
        -1 => "BEARISH"
        => "UNKNOWN"

// --- Trend State to Human-Readable String ---
trendToString(int trend) =>
    switch trend
        1  => "Bullish"
        -1 => "Bearish"
        => "Neutral"

// --- EMA Trend to Human-Readable String ---
emaTrendToString(int eTrend) =>
    eTrend == 1 ? "Bullish (Fast > Slow)" : "Bearish (Fast < Slow)"

// --- Build a Single Discord Embed Field (JSON Object) ---
// Discord embeds use an array of "field" objects, each with:
//   { "name": "Label", "value": "Content", "inline": true/false }
//
// `inline: true` places fields side-by-side (3 per row on desktop).
// `inline: false` gives the field its own full-width row.
//
// WHY A HELPER? Because we build 7-9 fields per alert. Without this,
// the concatenation code becomes an unreadable wall of quotes and braces.
// This function encapsulates the escaping and structure so each field
// is a clean one-liner in the calling code.
buildEmbedField(string fieldName, string fieldValue, bool isInline) =>
    '{"name":"' + jsonEscape(fieldName) + '","value":"' + jsonEscape(fieldValue) + '","inline":' + (isInline ? 'true' : 'false') + '}'

// --- Get Trigger Mode Label ---
// Maps the confirmationMode input to a clean, short label for the Reason field.
// The triggerEvent string from Section 9 contains the full detail (e.g.
// "CHoCH Bullish + EMA Aligned"), but for the "Trigger:" line we want
// a concise, standardized label that matches what the user selected.
getTriggerModeLabel() =>
    switch confirmationMode
        "CHoCH+EMA"        => "CHoCH + EMA"
        "CHoCHOnly"        => "CHoCH Only"
        "CHoCHThenBOS"     => "CHoCH → BOS"
        "CHoCHThenBOS+EMA" => "CHoCH → BOS + EMA"
        => confirmationMode

// --- Get EMA Alignment Description ---
// Returns a clean, standardized EMA status string.
getEmaDesc() =>
    emaTrend == 1
         ? "EMA" + str.tostring(fastEmaLen) + " > EMA" + str.tostring(slowEmaLen)
         : "EMA" + str.tostring(fastEmaLen) + " < EMA" + str.tostring(slowEmaLen)

// --- Get Dynamic Description Text ---
// Builds the embed description line based on BOTH direction AND confirmationMode.
//
// WHY DYNAMIC? A static "structure reversal confirmation" is vague. When the
// mode is CHoCHThenBOS or CHoCHThenBOS+EMA, the flip was confirmed by a BOS
// AFTER the initial CHoCH — that's a meaningfully different (and stronger)
// confirmation than a simple CHoCH+EMA. The description should reflect that
// so the trader instantly knows the quality of the signal at a glance.
getDescriptionText(string dirUpper) =>
    string modeDesc = switch confirmationMode
        "CHoCH+EMA"        => "structure reversal + EMA alignment"
        "CHoCHOnly"        => "structure reversal (CHoCH)"
        "CHoCHThenBOS"     => "CHoCH → BOS continuation"
        "CHoCHThenBOS+EMA" => "CHoCH → BOS continuation + EMA alignment"
        => "structure reversal confirmation"
    dirUpper + " regime confirmed after " + modeDesc + "."

// --- Get Meaning Text ---
getMeaningText(string direction) =>
    direction == "BULLISH"
         ? "Potential regime shift toward bullish continuation."
         : "Potential regime shift toward bearish continuation."

// --- Get Action Text ---
getActionText(string direction) =>
    direction == "BULLISH"
         ? "Prefer long bias on pullbacks / retests with confluence."
         : "Prefer short bias on rallies / retests with confluence."

// --- Get Price-Specific Invalidation Text ---
// States when the bias weakens, using the ACTUAL broken level price.
//
// WHY PRICE-SPECIFIC? "Closes back below the key broken structure" is vague.
// Including the exact price means the trader can set a stop or watchpoint
// immediately from the Discord notification without opening the chart.
//
// The broken level is:
//   Bullish flip → the swing HIGH that price broke above
//   Bearish flip → the swing LOW that price broke below
getInvalidationText(string direction, float brokenLevel) =>
    string lvlStr = na(brokenLevel) ? "the key structure level" : str.tostring(brokenLevel, format.mintick)
    direction == "BULLISH"
         ? "Invalidate if price closes back below " + lvlStr + " or EMA" + str.tostring(fastEmaLen) + " loses EMA" + str.tostring(slowEmaLen) + "."
         : "Invalidate if price closes back above " + lvlStr + " or EMA" + str.tostring(fastEmaLen) + " reclaims EMA" + str.tostring(slowEmaLen) + "."

// --- Determine the Broken Level Based on Flip Direction ---
// Picks the correct swing level that was violated to cause the flip.
// Bullish flip = price broke ABOVE the swing high → broken level is swingHigh
// Bearish flip = price broke BELOW the swing low  → broken level is swingLow
getBrokenLevel(string direction, float swingHighLvl, float swingLowLvl) =>
    direction == "Bullish" ? swingHighLvl : swingLowLvl

// ============================================================================
// ALERT PAYLOAD BUILDERS
// ============================================================================
// Two output formats controlled by `useEmbeds`:
//   1) EMBED (default): Rich card with colored sidebar and structured fields
//   2) CONTENT FALLBACK: Clean markdown for non-Discord webhook targets
//
// EMBED COLOR CODES (decimal — Discord requires decimal, not hex):
//   Green:  3066993  (hex #2ECC71)
//   Red:   15158332  (hex #E74C3C)
//   Orange: 16750848  (hex #FFA500)
// ============================================================================

// --- Build the Embed-Format Flip Alert ---
buildFlipAlertEmbed(string direction, string triggerEvent, float swingHighLvl, float swingLowLvl) =>
    // --- Precompute all display values ---
    string dirUpper    = direction == "Bullish" ? "BULLISH" : "BEARISH"
    string emoji       = direction == "Bullish" ? "🟢" : "🔴"
    string colorCode   = direction == "Bullish" ? "3066993" : "15158332"
    string cls         = str.tostring(close, format.mintick)
    string highLvl     = na(swingHighLvl) ? "N/A" : str.tostring(swingHighLvl, format.mintick)
    string lowLvl      = na(swingLowLvl)  ? "N/A" : str.tostring(swingLowLvl,  format.mintick)
    float  brokenLevel = getBrokenLevel(direction, swingHighLvl, swingLowLvl)
    string brokenStr   = na(brokenLevel) ? "N/A" : str.tostring(brokenLevel, format.mintick)
    string trendStr    = trendToString(trendState)
    string biasStr     = dirUpper
    string emaDesc     = getEmaDesc()
    string triggerMode = getTriggerModeLabel()
    string ts          = formatTimestamp()

    // --- Title and Description ---
    string title = emoji + " StrikeZone — BIAS FLIP | " + dirUpper
    string desc  = getDescriptionText(dirUpper)

    // --- Reason field ---
    // First line: the trigger mode label (matches the user's selected mode)
    // Below: the raw structure event detail, EMA filter, trend, and bias
    string reasonVal = "Trigger: " + triggerMode
         + "\n• " + triggerEvent
         + "\n• EMA Filter: " + emaDesc
         + "\n• Structure Trend: " + trendStr
         + "\n• Bias State: " + biasStr

    // --- Levels field ---
    // Broken Level first — the most actionable piece of info.
    // A trader scanning on mobile sees the critical level immediately.
    string levelsVal = "• Broken Level: " + brokenStr
         + "\n• Swing High: " + highLvl
         + "\n• Swing Low: " + lowLvl
         + "\n• Close: " + cls

    // --- Assemble embed fields ---
    string f1 = buildEmbedField("Symbol",    syminfo.tickerid,  true)
    string f2 = buildEmbedField("Timeframe", timeframe.period,  true)
    string f3 = buildEmbedField("Mode",      confirmationMode,  true)
    string f4 = buildEmbedField("Reason",    reasonVal,         false)
    string f5 = buildEmbedField("Levels",    levelsVal,         false)

    // --- Educational fields (compact mode skips these) ---
    string educationalFields = ""
    if not compactMode
        string f6 = buildEmbedField("Meaning",      getMeaningText(dirUpper),                    false)
        string f7 = buildEmbedField("Action",        getActionText(dirUpper),                     false)
        string f8 = buildEmbedField("Invalidation",  getInvalidationText(dirUpper, brokenLevel),  false)
        educationalFields := "," + f6 + "," + f7 + "," + f8

    string f9 = buildEmbedField("Time (GMT)", ts, false)

    // --- Assemble full JSON payload ---
    string json = '{"content":"",'
         + '"embeds":[{'
         + '"title":"' + jsonEscape(title) + '",'
         + '"description":"' + jsonEscape(desc) + '",'
         + '"color":' + colorCode + ','
         + '"fields":[' + f1 + ',' + f2 + ',' + f3 + ',' + f4 + ',' + f5
         + educationalFields
