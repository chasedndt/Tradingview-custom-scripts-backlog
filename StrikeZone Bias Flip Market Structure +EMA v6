// ============================================================================
// SECTION 6: SWING DETECTION (MSA Engine)
// ============================================================================
// This section is lifted directly from the MSA v2 logic.
//
// HOW PIVOTS WORK:
// ta.pivothigh(high, leftBars, rightBars) looks at a window of bars:
//   [leftBars bars to the left] [PIVOT BAR] [rightBars bars to the right]
//
// If the pivot bar's HIGH is higher than ALL bars in the window, it's confirmed
// as a swing high. The catch: it takes `rightBars` bars AFTER the actual high
// to confirm it. This is called the "pivot lag."
//
// Example with swingLen=5:
//   Bar 100 makes a high of 50000 (highest in range)
//   Bar 105: We NOW confirm that bar 100 was a swing high (5 bars later)
//
// This lag is actually GOOD for non-repainting. The pivot is only detected
// after it's already confirmed by subsequent price action.
// ============================================================================

// Update swing levels when new pivots are detected
// Note: pivotHigh/pivotLow were calculated at global scope in Section 3
if not na(pivotHigh)
    lastSwingHighLevel := pivotHigh
    lastSwingHighBar   := bar_index - swingLen   // Adjust for pivot lag

if not na(pivotLow)
    lastSwingLowLevel := pivotLow
    lastSwingLowBar   := bar_index - swingLen


// ============================================================================
// SECTION 7: STRUCTURE BREAK DETECTION (MSA Engine)
// ============================================================================
// Now we check if price has broken any of our tracked swing levels.
//
// THE STATE MACHINE LOGIC:
//   If trendState is +1 (bullish) and price breaks above swing high → BOS (continuation)
//   If trendState is -1 (bearish) and price breaks above swing high → CHoCH (reversal!)
//   If trendState is -1 (bearish) and price breaks below swing low  → BOS (continuation)
//   If trendState is +1 (bullish) and price breaks below swing low  → CHoCH (reversal!)
//
// BOS = "The trend is continuing, as expected"
// CHoCH = "Something changed! The other side is gaining control"
//
// This is the exact same logic used in Smart Money Concept (SMC) trading.
// ============================================================================

float buffer = getAtrBuffer()

// Gate evaluation behind bar close if required (non-repaint protection)
bool canEvaluate = requireBarClose ? barstate.isconfirmed : true

// Event flags — reset every bar (no `var` here, intentionally)
bool bullishBOS  = false
bool bearishBOS  = false
bool bullishCHoCH = false
bool bearishCHoCH = false

if canEvaluate
    // --- Check UPSIDE break (price broke above last swing high) ---
    // IMPORTANT: We use `else if` between upside and downside checks.
    //
    // WHY? On extremely volatile bars (flash crashes, news spikes), a single
    // candle's wick can breach BOTH the swing high AND swing low. With two
    // separate `if` blocks, both a bullish AND bearish event would fire on
    // the same bar — creating contradictory signals and potentially two
    // alerts to Discord for the same candle.
    //
    // By using `else if`, we enforce: ONE structure event per bar, maximum.
    //
    // PRIORITY: Upside break wins if both are possible. Why?
    //   - If a candle breaks both levels, it closed somewhere. The close
    //     determines which break is "real" in Close mode.
    //   - In practice this almost never happens with Close mode (a candle
    //     can't close above swing high AND below swing low simultaneously).
    //   - In Wick mode it's theoretically possible, so the priority matters.
    //   - Upside-first is arbitrary but consistent. The key is predictability.
    if hasBrokenAbove(lastSwingHighLevel, buffer)
        if trendState == 1 or trendState == 0
            bullishBOS := true       // Continuation — already bullish
        else if trendState == -1
            bullishCHoCH := true     // REVERSAL — was bearish, now breaking up

    // --- Check DOWNSIDE break (price broke below last swing low) ---
    // Only evaluated if NO upside break occurred this bar (else if)
    else if hasBrokenBelow(lastSwingLowLevel, buffer)
        if trendState == -1 or trendState == 0
            bearishBOS := true       // Continuation — already bearish
        else if trendState == 1
            bearishCHoCH := true     // REVERSAL — was bullish, now breaking down


// ============================================================================
// SECTION 8: TREND STATE UPDATE (MSA Engine)
// ============================================================================
// Update the raw structure trendState based on detected events.
// Also invalidate (reset to na) the broken swing level so we don't
// re-trigger on the same level next bar.
//
// WHY INVALIDATE? Without this, if price stays above the swing high
// for 10 bars, we'd get 10 BOS signals instead of 1. Setting the level
// to na forces us to wait for a NEW swing pivot before checking again.
// ============================================================================

// We capture the swing levels BEFORE invalidation so they can be
// referenced in alert messages and bias logic below.
float eventSwingHigh = lastSwingHighLevel
float eventSwingLow  = lastSwingLowLevel

// IMPORTANT: These are chained with `else if` to ensure exactly ONE
// state transition per bar. Combined with the Section 7 patch (which
// already ensures only one event flag is true), this is belt-and-suspenders
// safety. If somehow two flags were both true (shouldn't happen with the
// else-if in Section 7, but defensive coding means planning for "shouldn't"),
// only the first matching block executes.
//
// PRIORITY ORDER: bullishBOS → bearishBOS → bullishCHoCH → bearishCHoCH
// BOS is checked first because if both a BOS and CHoCH fired (impossible
// with current logic, but future-proofing), continuation is the safer assumption.
if bullishBOS
    trendState         := 1
    lastSwingHighLevel := na
    lastSwingHighBar   := na

else if bearishBOS
    trendState        := -1
    lastSwingLowLevel := na
    lastSwingLowBar   := na

else if bullishCHoCH
    trendState         := 1
    lastSwingHighLevel := na
    lastSwingHighBar   := na

else if bearishCHoCH
    trendState        := -1
    lastSwingLowLevel := na
    lastSwingLowBar   := na


// ============================================================================
// SECTION 9: BIAS FLIP LOGIC (THE CORE INNOVATION)
// ============================================================================
// This is where the indicator adds value beyond raw MSA signals.
//
// Raw BOS/CHoCH events happen frequently and many are noise. The bias flip
// system FILTERS these through confirmation requirements (EMA alignment,
// BOS follow-through) to produce high-confidence regime change signals.
//
// CONFIRMATION MODES EXPLAINED:
//
// 1) "CHoCH+EMA" (DEFAULT, RECOMMENDED):
//    Bias flips when: CHoCH occurs AND EMA fast/slow alignment agrees.
//    Example: Bullish CHoCH fires + EMA 21 is above EMA 55 → BULLISH FLIP
//    This filters out CHoCH signals that occur against the broader trend.
//
// 2) "CHoCHOnly":
//    Bias flips immediately on any CHoCH. No EMA filter.
//    Fastest response but most false signals. Good for scalpers who want
//    to react to every potential reversal and filter manually.
//
// 3) "CHoCHThenBOS":
//    CHoCH sets a "pending" flip. Bias only actually flips when a BOS
//    follows in the same direction. This confirms the reversal with
//    continuation proof.
//    Example: Bullish CHoCH → pendingFlipDir = +1 → wait → Bullish BOS → FLIP!
//
// 4) "CHoCHThenBOS+EMA":
//    Same as #3, but the confirming BOS bar must also have EMA alignment.
//    Maximum confirmation. Fewest signals but highest conviction.
//
// COOLDOWN: After any flip, we wait minBarsBetweenFlips before allowing
// another. This prevents rapid flip-flopping in consolidation zones.
// ============================================================================

// Cooldown check: have enough bars passed since last flip?
bool cooldownClear = (bar_index - lastFlipBar) > minBarsBetweenFlips

// --- Bias Flip Event Flags ---
bool bullishFlip = false
bool bearishFlip = false
string flipTriggerEvent = ""

// --- MODE: CHoCH+EMA (default) ---
// Within each mode, we use `else if` between bullish and bearish checks.
// This guarantees at most ONE flip direction per bar per mode.
if confirmationMode == "CHoCH+EMA"
    // Bullish flip: CHoCH up + EMA bullish
    if bullishCHoCH and emaTrend == 1 and cooldownClear and biasState != 1
        bullishFlip      := true
        flipTriggerEvent := "CHoCH Bullish + EMA Aligned"
    // Bearish flip: CHoCH down + EMA bearish (else if = mutually exclusive)
    else if bearishCHoCH and emaTrend == -1 and cooldownClear and biasState != -1
        bearishFlip      := true
        flipTriggerEvent := "CHoCH Bearish + EMA Aligned"

// --- MODE: CHoCHOnly ---
else if confirmationMode == "CHoCHOnly"
    if bullishCHoCH and cooldownClear and biasState != 1
        bullishFlip      := true
        flipTriggerEvent := "CHoCH Bullish (no EMA filter)"
    else if bearishCHoCH and cooldownClear and biasState != -1
        bearishFlip      := true
        flipTriggerEvent := "CHoCH Bearish (no EMA filter)"

// --- MODE: CHoCHThenBOS ---
else if confirmationMode == "CHoCHThenBOS"
    // Step 1: CHoCH sets pending direction
    // Use else-if here too: if both CHoCH directions fire (shouldn't happen
    // after Section 7 patch, but defensive), bullish takes priority
    if bullishCHoCH
        pendingFlipDir := 1
    else if bearishCHoCH
        pendingFlipDir := -1

    // Step 2: BOS in same direction confirms the flip
    if pendingFlipDir == 1 and bullishBOS and cooldownClear and biasState != 1
        bullishFlip      := true
        flipTriggerEvent := "CHoCH → BOS Confirmed Bullish"
        pendingFlipDir   := 0   // Clear pending state
    else if pendingFlipDir == -1 and bearishBOS and cooldownClear and biasState != -1
        bearishFlip      := true
        flipTriggerEvent := "CHoCH → BOS Confirmed Bearish"
        pendingFlipDir   := 0

    // Cancel pending if opposite CHoCH occurs (invalidates the setup)
    // This runs AFTER the BOS checks above, so a confirming BOS is processed
    // before we consider cancelling. The else-if prevents double-cancel.
    if pendingFlipDir == 1 and bearishCHoCH
        pendingFlipDir := -1   // Overwrite with new direction
    else if pendingFlipDir == -1 and bullishCHoCH
        pendingFlipDir := 1

// --- MODE: CHoCHThenBOS+EMA ---
else if confirmationMode == "CHoCHThenBOS+EMA"
    // Step 1: CHoCH sets pending direction
    if bullishCHoCH
        pendingFlipDir := 1
    else if bearishCHoCH
        pendingFlipDir := -1

    // Step 2: BOS in same direction + EMA alignment confirms
    if pendingFlipDir == 1 and bullishBOS and emaTrend == 1 and cooldownClear and biasState != 1
        bullishFlip      := true
        flipTriggerEvent := "CHoCH → BOS + EMA Confirmed Bullish"
        pendingFlipDir   := 0
    else if pendingFlipDir == -1 and bearishBOS and emaTrend == -1 and cooldownClear and biasState != -1
        bearishFlip      := true
        flipTriggerEvent := "CHoCH → BOS + EMA Confirmed Bearish"
        pendingFlipDir   := 0

    // Cancel pending if opposite CHoCH occurs
    if pendingFlipDir == 1 and bearishCHoCH
        pendingFlipDir := -1
    else if pendingFlipDir == -1 and bullishCHoCH
        pendingFlipDir := 1

// ============================================================================
// CONFLICT RESOLVER (Belt-and-Suspenders Safety Net)
// ============================================================================
// After all mode logic, we check for the "impossible" case: both bullishFlip
// and bearishFlip are true on the same bar.
//
// WHY THIS EXISTS:
// The else-if chains above should make this impossible. But in production code
// that sends real alerts to Discord (which traders act on with real money),
// "should be impossible" isn't good enough. We need a hard guarantee.
//
// RESOLUTION STRATEGY:
// If both are true, we use emaTrend as the tiebreaker:
//   - If EMA is bullish → keep bullishFlip, cancel bearishFlip
//   - If EMA is bearish → keep bearishFlip, cancel bullishFlip
//   - If somehow EMA gives no clear answer → block BOTH flips (do nothing)
//
// The philosophy: when in doubt, defer to the higher-timeframe trend (EMA),
// and if even THAT is ambiguous, do nothing. Missing one signal is always
// better than sending a wrong signal.
//
// In practice, this block should NEVER execute. If it does, the debug plot
// "Conflict Detected" will show 1 on that bar so you can investigate.
// ============================================================================

bool conflictDetected = false

if bullishFlip and bearishFlip
    conflictDetected := true
    if emaTrend == 1
        // EMA says bullish — trust the bullish flip, cancel bearish
        bearishFlip      := false
        flipTriggerEvent := flipTriggerEvent + " [CONFLICT: EMA tiebreak → Bull]"
    else if emaTrend == -1
        // EMA says bearish — trust the bearish flip, cancel bullish
        bullishFlip      := false
        flipTriggerEvent := flipTriggerEvent + " [CONFLICT: EMA tiebreak → Bear]"
    else
        // EMA is ambiguous — block both, don't flip at all
        bullishFlip      := false
        bearishFlip      := false
        flipTriggerEvent := "BLOCKED: Conflicting signals, no flip"


// ============================================================================
// SECTION 10: BIAS STATE UPDATE & ALERT DISPATCH
// ============================================================================
// When a flip is confirmed, we:
//   1) Update biasState to the new direction
//   2) Record the bar index for cooldown tracking
//   3) Draw a label on the chart
//   4) Fire the Discord webhook alert
//
// For early warnings (optional), we fire a separate alert on CHoCH events
// even when they haven't triggered a full bias flip yet.
// ============================================================================

// --- Process Bullish Flip ---
if bullishFlip
    biasState   := 1
    lastFlipBar := bar_index

    // Draw flip label
    if showFlipLabels
        label newLabel = label.new(
             x         = bar_index,
             y         = low,
             text      = "BIAS FLIP ↑",
             style     = label.style_label_up,
             color     = COLOR_FLIP_BULL,
             textcolor = color.white,
             size      = getLabelSize())
        array.push(flipLabels, newLabel)

    // Fire alert
    if enableAlerts and alertBullFlip
        string jsonMsg = buildFlipAlertJson("Bullish", flipTriggerEvent, eventSwingHigh, eventSwingLow)
        alert(jsonMsg, alert.freq_once_per_bar_close)

// --- Process Bearish Flip ---
if bearishFlip
    biasState   := -1
    lastFlipBar := bar_index

    if showFlipLabels
        label newLabel = label.new(
             x         = bar_index,
             y         = high,
             text      = "BIAS FLIP ↓",
             style     = label.style_label_down,
             color     = COLOR_FLIP_BEAR,
             textcolor = color.white,
             size      = getLabelSize())
        array.push(flipLabels, newLabel)

    if enableAlerts and alertBearFlip
        string jsonMsg = buildFlipAlertJson("Bearish", flipTriggerEvent, eventSwingHigh, eventSwingLow)
        alert(jsonMsg, alert.freq_once_per_bar_close)

// --- Early Warning Alerts (optional) ---
// These fire on CHoCH events REGARDLESS of whether they trigger a bias flip.
// Useful for traders who want a "heads up" before the full confirmation.
if enableEarlyWarning and enableAlerts
    if bullishCHoCH and not bullishFlip
        string ewJson = buildEarlyWarningJson("Bullish", "CHoCH")
        alert(ewJson, alert.freq_once_per_bar_close)
    if bearishCHoCH and not bearishFlip
        string ewJson = buildEarlyWarningJson("Bearish", "CHoCH")
        alert(ewJson, alert.freq_once_per_bar_close)


// ============================================================================
// SECTION 11: VISUAL RENDERING
// ============================================================================
// Good visuals turn a good indicator into a GREAT one. The goal is to give
// the trader an instant "at a glance" understanding of the current state.
//
// We render:
//   1) Background shading (faint green/red for current bias)
//   2) EMA lines (so the user can see trend alignment)
//   3) Swing level lines (current structure boundaries)
//   4) Info panel table (dashboard showing all states)
// ============================================================================

// --- Cleanup Old Labels ---
cleanupOldLabels(flipLabels, maxEventsToKeep)

// --- Background Shading ---
color bgColor = na
if showBgShading
    bgColor := switch biasState
        1  => COLOR_BG_BULL
        -1 => COLOR_BG_BEAR
        => na
bgcolor(bgColor, title="Bias State Background")

// --- EMA Lines ---
plot(showEMAs ? emaFast : na, "EMA Fast", color = color.new(color.blue,   0), linewidth = 2)
plot(showEMAs ? emaSlow : na, "EMA Slow", color = color.new(color.orange, 0), linewidth = 2)

// --- Swing Level Lines ---
// We only update these on the last (rightmost) bar for performance.
// Drawing on every bar would create thousands of unnecessary line objects.
if showSwingLevels and barstate.islast
    // Delete old lines before drawing new ones
    if not na(activeHighLine)
        line.delete(activeHighLine)
    if not na(activeLowLine)
        line.delete(activeLowLine)

    if not na(lastSwingHighLevel)
        activeHighLine := line.new(
             x1    = lastSwingHighBar,
             y1    = lastSwingHighLevel,
             x2    = bar_index,
             y2    = lastSwingHighLevel,
             color = COLOR_SWING_HIGH,
             width = 1,
             style = line.style_dashed)

    if not na(lastSwingLowLevel)
        activeLowLine := line.new(
             x1    = lastSwingLowBar,
             y1    = lastSwingLowLevel,
             x2    = bar_index,
             y2    = lastSwingLowLevel,
             color = COLOR_SWING_LOW,
             width = 1,
             style = line.style_dashed)


// ============================================================================
// SECTION 12: STATUS PANEL (Info Table)
// ============================================================================
// The status panel is a small table in the top-right corner of the chart.
// It shows the current state of all three engines at a glance.
//
// WHY A TABLE? Because the bias state, EMA trend, and structure trend can
// all be different at any given time. The table lets the trader see:
//   "Oh, structure is bullish but EMA is still bearish — that's why we
//    haven't flipped yet."
//
// We only draw the table on the LAST bar (barstate.islast) for performance.
// Tables are expensive to render, so we don't want to recreate them on
// every historical bar.
// ============================================================================

if showInfoPanel and barstate.islast
    var table infoTable = table.new(
         position = position.top_right,
         columns  = 2,
         rows     = 7,
         bgcolor  = color.new(color.black, 30),
         frame_color   = color.gray,
         frame_width   = 1,
         border_color  = color.gray,
         border_width  = 1)

    // --- Header ---
    table.cell(infoTable, 0, 0, "StrikeZone Bias",
         text_color = color.white,
         text_size  = size.small,
         bgcolor    = color.new(color.gray, 50))
    table.cell(infoTable, 1, 0, "",
         bgcolor = color.new(color.gray, 50))

    // --- Bias State (the big one) ---
    color biasColor = switch biasState
        1  => color.green
        -1 => color.red
        => color.gray
    table.cell(infoTable, 0, 1, "Bias",
         text_color = color.white, text_size = size.small)
    table.cell(infoTable, 1, 1, biasToString(biasState),
         text_color = biasColor,  text_size = size.small)

    // --- EMA Trend ---
    color emaColor = emaTrend == 1 ? color.green : color.red
    table.cell(infoTable, 0, 2, "EMA Trend",
         text_color = color.white, text_size = size.small)
    table.cell(infoTable, 1, 2, emaTrendToString(emaTrend),
         text_color = emaColor,  text_size = size.small)

    // --- Structure Trend ---
    color structColor = switch trendState
        1  => color.green
        -1 => color.red
        => color.gray
    table.cell(infoTable, 0, 3, "Structure",
         text_color = color.white, text_size = size.small)
    table.cell(infoTable, 1, 3, trendToString(trendState),
         text_color = structColor, text_size = size.small)

    // --- Mode ---
    table.cell(infoTable, 0, 4, "Mode",
         text_color = color.white, text_size = size.small)
    table.cell(infoTable, 1, 4, confirmationMode,
         text_color = color.yellow, text_size = size.small)

    // --- Swing High ---
    string shTxt = na(lastSwingHighLevel) ? "—" : str.tostring(lastSwingHighLevel, "#.####")
    table.cell(infoTable, 0, 5, "Swing High",
         text_color = color.white, text_size = size.small)
    table.cell(infoTable, 1, 5, shTxt,
         text_color = COLOR_SWING_HIGH, text_size = size.small)

    // --- Swing Low ---
    string slTxt = na(lastSwingLowLevel) ? "—" : str.tostring(lastSwingLowLevel, "#.####")
    table.cell(infoTable, 0, 6, "Swing Low",
         text_color = color.white, text_size = size.small)
    table.cell(infoTable, 1, 6, slTxt,
         text_color = COLOR_SWING_LOW, text_size = size.small)


